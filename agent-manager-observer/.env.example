# Server Configuration
AM_OBSERVER_PORT=9098

LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Observer Service Configuration
# -----------------------------------------------------------------------------
OPENCHOREO_OBSERVER_URL=http://localhost:8085
IDP_TOKEN_URL=http://localhost:8090/oauth2/token
IDP_CLIENT_ID=amp-api-client
IDP_CLIENT_SECRET=amp-api-client-secret

# Namespace all trace queries are scoped to (single-namespace deployment).
OBSERVER_DEFAULT_NAMESPACE=default

# -----------------------------------------------------------------------------
# Development Environment
# Set IS_LOCAL_DEV_ENV=true to skip JWT validation (local dev only).
# In production, set IS_LOCAL_DEV_ENV=false and configure the Key Manager below.
# -----------------------------------------------------------------------------
IS_LOCAL_DEV_ENV=true

# -----------------------------------------------------------------------------
# Key Manager Configuration (must match agent-manager-service values)
# The UI sends the same JWT to both services, so validation config must be identical.
# Required when IS_LOCAL_DEV_ENV=false.
# -----------------------------------------------------------------------------
# KEY_MANAGER_JWKS_URL=
# KEY_MANAGER_ISSUER=Agent Management Platform Local
# KEY_MANAGER_AUDIENCE=localhost
