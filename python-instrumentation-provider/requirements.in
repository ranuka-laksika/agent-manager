# Loose dependency inputs for the instrumentation provider image.
# traceloop-sdk (OpenLLMetry) is added at lock time from the TRACELOOP_VERSION
# in .github/release-config.json (see scripts/gen-locks.sh); this file holds
# only the always-needed extras. The image installs the compiled locks/ files,
# not this file directly.
# Pin wrapt below 2.0: wrapt 2.x removed the `module=` kwarg on
# wrap_function_wrapper that opentelemetry-instrumentation-* still calls.
wrapt<2.0.0
